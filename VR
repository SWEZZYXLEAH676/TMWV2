                local dropBg = dropdown:GetChildren()[3]
                dropBg.ZIndex = dropBg.ZIndex + windowCount * 10
                dropBg.ImageTransparency = options.title_bar_transparency or 0
                applyColor(dropBg, options.title_bar, 0)
                box.ImageTransparency = options.background_transparency or 0.1
                applyColor(box, options.background, 0)
                local boxCorner = Instance.new("UICorner")
                boxCorner.CornerRadius = UDim.new(0, 6)
                boxCorner.Parent = box
                items.BackgroundTransparency = 1
                items.Position = UDim2.new(0, 0, 0, 0)
                items.Size = UDim2.new(1, 0, 1, 0)
                local parent = tabContent:FindFirstChild("TabScroller")
                dropdown.Parent = parent or tabContent
                dropdown.Text = "      " .. text
                box.Size = UDim2.new(1, 0, 0, 0)
                box.Position = UDim2.new(0, 0, 0, 25)
                dropdown.TextColor3 = Color3.new(1, 1, 1)
                local isOpen = false
                local flippedUp = false
                dropdown.MouseButton1Click:Connect(function()
                    isOpen = not isOpen
                    local itemCount = #items:GetChildren() - 1
                    local targetH = math.min(itemCount * 20, 200)
                    if itemCount >= 10 then items.CanvasSize = UDim2.new(0, 0, itemCount * 0.1, 0) end
                    if isOpen then
                        if isDropdownOpen then return end
                        isDropdownOpen = true
                        local spaceBelow = (window.AbsolutePosition.Y + window.AbsoluteSize.Y) - (dropdown.AbsolutePosition.Y + dropdown.AbsoluteSize.Y)
                        if spaceBelow < targetH then
                            flippedUp = true
                            box.Position = UDim2.new(0, 0, 0, -targetH - 5)
                            box.Size = UDim2.new(1, 0, 0, 0)
                            tween(box, { Size = UDim2.new(1, 0, 0, targetH), Position = UDim2.new(0, 0, 0, -targetH - 5) }, options.tween_time)
                        else
                            flippedUp = false
                            box.Position = UDim2.new(0, 0, 0, 25)
                            box.Size = UDim2.new(1, 0, 0, 0)
                            tween(box, { Size = UDim2.new(1, 0, 0, targetH) }, options.tween_time)
                        end
                        tween(arrow, { Rotation = 90 }, options.tween_time)
                    else
                        isDropdownOpen = false
                        if flippedUp then
                            local t = TweenService:Create(box, TweenInfo.new(options.tween_time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 0, -5) })
                            t:Play()
                            t.Completed:Connect(function() box.Position = UDim2.new(0, 0, 0, 25) end)
                        else
                            tween(box, { Size = UDim2.new(1, 0, 0, 0) }, options.tween_time)
                        end
                        tween(arrow, { Rotation = -90 }, options.tween_time)
                    end
                end)
                function dropdownAPI:Add(itemText)
                    local itemAPI = {}
                    itemText = tostring(itemText or "New Object")
                    local item = Prefabs:FindFirstChild("DropdownButton"):Clone()
                    item.Parent = items
                    item.Text = "      " .. itemText
                    item.ZIndex = item.ZIndex + windowCount * 10 + 5
                    item.BackgroundTransparency = 1
                    item.TextColor3 = Color3.new(1, 1, 1)
                    item.BorderSizePixel = 0
                    item.TextXAlignment = Enum.TextXAlignment.Left
                    local existingCorner = item:FindFirstChildOfClass("UICorner")
                    if existingCorner then existingCorner:Destroy() end
                    local stroke = Instance.new("UIStroke")
                    stroke.Color = Color3.new(0, 0, 0)
                    stroke.Thickness = 1
                    stroke.Transparency = 0.3
                    stroke.Parent = item
                    item.MouseEnter:Connect(function() item.BackgroundTransparency = 0.8; item.BackgroundColor3 = options.main_color end)
                    item.MouseLeave:Connect(function() item.BackgroundTransparency = 1 end)
                    if isOpen then
                        local newH = math.min((#items:GetChildren() - 1) * 20, 200)
                        if #items:GetChildren() - 1 >= 10 then items.CanvasSize = UDim2.new(0, 0, (#items:GetChildren() - 1) * 0.1, 0) end
                        if flippedUp then
                            tween(box, { Size = UDim2.new(1, 0, 0, newH), Position = UDim2.new(0, 0, 0, -newH - 5) }, options.tween_time)
                        else
                            tween(box, { Size = UDim2.new(1, 0, 0, newH) }, options.tween_time)
                        end
                    end
                    item.MouseButton1Click:Connect(function()
                        if isDropdownOpen then
                            dropdown.Text = "      [ " .. itemText .. " ]"
                            isDropdownOpen = false
                            isOpen = false
                            if flippedUp then
                                local t = TweenService:Create(box, TweenInfo.new(options.tween_time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 0, -5) })
                                t:Play()
                                t.Completed:Connect(function() box.Position = UDim2.new(0, 0, 0, 25) end)
                            else
                                tween(box, { Size = UDim2.new(1, 0, 0, 0) }, options.tween_time)
                            end
                            tween(arrow, { Rotation = -90 }, options.tween_time)
                            pcall(callback, itemText)
                        end
                    end)
                    function itemAPI:Remove() item:Destroy() end
                    return item, itemAPI
                end
                function dropdownAPI:Remove(itemText)
                    local item = items:FindFirstChild(itemText)
                    if item then
                        item:Destroy()
                        if dropdownAPI.currentSelection == itemText then
                            local first = items:GetChildren()[1]
                            local newSel = first and first.Text or "No Selection"
                            dropdownAPI.currentSelection = newSel
                            dropdown.Text = "        [ " .. newSel .. " ]"
                            pcall(callback, newSel)
                        end
                    end
                end
                return dropdownAPI, dropdown
            end

            function tabAPI:AddColorPicker(callback)
                local pickerAPI = {}
                callback = typeof(callback) == "function" and callback or function() end
                local picker = Prefabs:FindFirstChild("ColorPicker"):Clone()
                local parent = tabContent:FindFirstChild("TabScroller")
