            function tabAPI:AddFolder(folderName)
                local folderAPI = {}
                folderName = tostring(folderName or "New Folder")
                local folder = Prefabs:FindFirstChild("Folder"):Clone()
                local btn = folder:FindFirstChild("Button")
                local contents = folder:FindFirstChild("Objects")
                local toggleIcon = btn:FindFirstChild("Toggle")
                folder.ZIndex = folder.ZIndex + windowCount * 10
                btn.ZIndex = btn.ZIndex + windowCount * 10
                contents.ZIndex = contents.ZIndex + windowCount * 10
                toggleIcon.ZIndex = toggleIcon.ZIndex + windowCount * 10
                btn:GetChildren()[1].ZIndex = btn:GetChildren()[1].ZIndex + windowCount * 10
                local parent = tabContent:FindFirstChild("TabScroller")
                folder.Parent = parent or tabContent
                btn.Text = "      " .. folderName
                btn:GetChildren()[1].ImageColor3 = options.main_color
                local function getFolderHeight()
                    local h = 25
                    for _, child in ipairs(contents:GetChildren()) do
                        if not child:IsA("UIListLayout") then h = h + child.AbsoluteSize.Y + 5 end
                    end
                    return h
                end
                local isFolderOpen = false
                local folderHbConn
                btn.MouseButton1Click:Connect(function()
                    isFolderOpen = not isFolderOpen
                    if isFolderOpen then
                        tween(toggleIcon, { Rotation = 90 }, options.tween_time)
                        contents.Visible = true
                        if folderHbConn then folderHbConn:Disconnect() end
                        folderHbConn = RunService.Heartbeat:Connect(function()
                            if isFolderOpen then
                                folder.Size = UDim2.new(1, 0, 0, getFolderHeight())
                            else
                                if folderHbConn then folderHbConn:Disconnect(); folderHbConn = nil end
                            end
                        end)
                    else
                        tween(toggleIcon, { Rotation = 0 }, options.tween_time)
                        contents.Visible = false
                        folder.Size = UDim2.new(1, 0, 0, 20)
                        if folderHbConn then folderHbConn:Disconnect(); folderHbConn = nil end
                    end
                end)
                for method, fn in pairs(tabAPI) do
                    folderAPI[method] = function(...)
                        local results = { fn(...) }
                        results[#results].Parent = contents
                        return table.unpack(results)
                    end
                end
                return folderAPI, folder
            end

            return tabAPI, tabContent
        end
    end

    for _, child in ipairs(window:GetDescendants()) do
        if safeGet(child, "ZIndex") then child.ZIndex = child.ZIndex + windowCount * 10 end
    end

    return windowAPI, window
end

