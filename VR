local function playRipple(parent, mouseX, mouseY)
    task.spawn(function()
        parent.ClipsDescendants = true
        local circle = Prefabs:FindFirstChild("Circle"):Clone()
        circle.Parent = parent
        circle.ZIndex = 1000
        circle.Position = UDim2.new(0, mouseX - circle.AbsolutePosition.X, 0, mouseY - circle.AbsolutePosition.Y)
        local size = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.5
        circle:TweenSizeAndPosition(UDim2.new(0, size, 0, size), UDim2.new(0.5, -size / 2, 0.5, -size / 2), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.5, false)
        tween(circle, { ImageTransparency = 1 }, 0.5)
        task.wait(0.5)
        circle:Destroy()
    end)
end

