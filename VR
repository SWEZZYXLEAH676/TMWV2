                palette.ZIndex = palette.ZIndex + windowCount * 10
                sample.ZIndex = sample.ZIndex + windowCount * 10
                saturation.ZIndex = saturation.ZIndex + windowCount * 10
                local hue, sat, val = 0, 1, 1
                local function updateColor()
                    local color = Color3.fromHSV(hue, sat, val)
                    sample.ImageColor3 = color
                    saturation.ImageColor3 = Color3.fromHSV(hue, 1, 1)
                    pcall(callback, color)
                end
                sample.ImageColor3 = Color3.fromHSV(hue, sat, val)
                saturation.ImageColor3 = Color3.fromHSV(hue, 1, 1)
                local hoverPalette, hoverSat = false, false
                palette.MouseEnter:Connect(function() window.Draggable = false; hoverPalette = true end)
                palette.MouseLeave:Connect(function() window.Draggable = true; hoverPalette = false end)
                saturation.MouseEnter:Connect(function() window.Draggable = false; hoverSat = true end)
                saturation.MouseLeave:Connect(function() window.Draggable = true; hoverSat = false end)
                local palInd = palette:FindFirstChild("Indicator")
                local satInd = saturation:FindFirstChild("Indicator")
                palInd.ZIndex = palInd.ZIndex + windowCount * 10
                satInd.ZIndex = satInd.ZIndex + windowCount * 10
                local isMouseDown = false
                local hbConn
                UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        isMouseDown = true
                        hbConn = RunService.Heartbeat:Connect(function()
                            if not isMouseDown or isDropdownOpen then
                                if hbConn then hbConn:Disconnect(); hbConn = nil end
                                return
                            end
                            if hoverPalette then
                                local pos = getMousePosition()
                                local fx = math.clamp((pos.X - palette.AbsolutePosition.X) / palette.AbsoluteSize.X, 0, 1)
                                local fy = math.clamp((pos.Y - palette.AbsolutePosition.Y) / palette.AbsoluteSize.Y, 0, 1)
                                hue = fx; sat = 1 - fy
                                palInd.Position = UDim2.new(fx, -palInd.AbsoluteSize.X / 2, fy, -palInd.AbsoluteSize.Y / 2)
                                updateColor()
                            elseif hoverSat then
                                local pos = getMousePosition()
                                local fy = math.clamp((pos.Y - saturation.AbsolutePosition.Y) / saturation.AbsoluteSize.Y, 0, 1)
                                val = 1 - fy
                                satInd.Position = UDim2.new(0, 0, fy, 0)
                                updateColor()
                            end
                        end)
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        isMouseDown = false
                        if hbConn then hbConn:Disconnect(); hbConn = nil end
                    end
                end)
                function pickerAPI:Set(color)
                    color = typeof(color) == "Color3" and color or Color3.new(1, 1, 1)
                    local h, s, v = rgbToHsv(color.R * 255, color.G * 255, color.B * 255)
                    sample.ImageColor3 = color
                    saturation.ImageColor3 = Color3.fromHSV(h, 1, 1)
                    pcall(callback, color)
