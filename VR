function Library:AddWindow(title, options)
    windowCount = windowCount + 1
    local isDropdownOpen = false
    title = tostring(title or "New Window")
    options = typeof(options) == "table" and options or Config
    options.tween_time = options.tween_time or 0.1
    options.title_bar = options.title_bar or { Color3.fromRGB(41, 74, 122) }
    if typeof(options.title_bar) == "Color3" then options.title_bar = { options.title_bar } end
    options.title_bar_transparency = options.title_bar_transparency or 0
    options.background = options.background or { Color3.new(0.08, 0.09, 0.1) }
    if typeof(options.background) == "Color3" then options.background = { options.background } end
    options.background_transparency = options.background_transparency or 0.1
    if not options.main_color then options.main_color = options.title_bar[1] end

    local window = Prefabs:FindFirstChild("Window"):Clone()
    window.Parent = WindowsContainer
    window:FindFirstChild("Title").Text = title
    window.Size = UDim2.new(0, options.min_size.X, 0, options.min_size.Y)
    window.ZIndex = window.ZIndex + windowCount * 10

    do
        local bar = window:FindFirstChild("Bar")
        local barTitle = bar:FindFirstChild("Title")
        local toggle = bar:FindFirstChild("Toggle")
        local base = bar:FindFirstChild("Base")
        local top = bar:FindFirstChild("Top")
        local tabSelection = window:FindFirstChild("TabSelection")
        local tabFrame = tabSelection:FindFirstChild("Frame")
        local barHeight = 24
        local barPadding = (barHeight - 18) / 2
        bar.Size = UDim2.new(1, 0, 0, barHeight)
        bar.Position = UDim2.new(0, 0, 0, 0)
        if base then base:Destroy() end
        if top then top:Destroy() end
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 5)
        corner.Parent = bar
        if toggle then toggle.Position = UDim2.new(0, 5, 0, barPadding) end
        if barTitle then
            barTitle.Position = UDim2.new(0, 25, 0, barPadding)
            barTitle.Size = UDim2.new(1, -30, 1, -barPadding * 2)
            barTitle.TextXAlignment = Enum.TextXAlignment.Center
        end
        bar.BackgroundTransparency = options.title_bar_transparency
        applyColor(bar, options.title_bar, 0)
        if tabSelection then
            tabSelection.Size = UDim2.new(1, -30, 0, 22)
            tabSelection.Position = UDim2.new(0, 15, 0, 28)
            local tabCorner = Instance.new("UICorner")
            tabCorner.CornerRadius = UDim.new(0, 6)
            tabCorner.Parent = tabSelection
            tabSelection.ImageTransparency = 0.4
            applyColor(tabSelection, options.title_bar, 45)
            local scrolling = tabSelection:FindFirstChild("TabScrolling")
            if scrolling then
                local buttons = scrolling:FindFirstChild("TabButtons")
                if buttons then
                    local layout = buttons:FindFirstChildOfClass("UIListLayout")
                    if layout then
                        layout.VerticalAlignment = Enum.VerticalAlignment.Center
                        layout.Padding = UDim.new(0, 12)
                    end
                end
            end
            if tabFrame then tabFrame:Destroy() end
        end
        window.ImageTransparency = options.background_transparency
        applyColor(window, options.background, 45)
        local tabsContainer = window:FindFirstChild("Tabs")
        toggle.MouseButton1Click:Connect(function()
            if tabsContainer.Visible then
                tabsContainer.Visible = false
                tween(window, { Size = UDim2.new(0, window.AbsoluteSize.X, 0, barHeight) }, options.tween_time)
            else
                tabsContainer.Visible = true
                window.Size = UDim2.new(0, window.AbsoluteSize.X, 0, options.min_size.Y)
            end
        end)
    end

    local resizer = window:WaitForChild("Resizer")
    local windowAPI = {}

    do
        local originalCursor = Mouse.Icon
        local isHoveringResizer = false
        resizer.MouseEnter:Connect(function()
            window.Draggable = false
            if options.can_resize then originalCursor = Mouse.Icon end
            isHoveringResizer = true
        end)
        resizer.MouseLeave:Connect(function()
            isHoveringResizer = false
            if options.can_resize then Mouse.Icon = originalCursor end
            window.Draggable = true
        end)
        local isMouseDown = false
        local heartbeatConn
        UserInputService.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                isMouseDown = true
                if isHoveringResizer and resizer.Active and options.can_resize then
                    heartbeatConn = RunService.Heartbeat:Connect(function()
                        if not isMouseDown or not resizer.Active then
                            if heartbeatConn then heartbeatConn:Disconnect(); heartbeatConn = nil end
                            return
                        end
                        local pos = getMousePosition()
                        local w = math.max(options.min_size.X, pos.X - window.AbsolutePosition.X)
                        local h = math.max(options.min_size.Y, pos.Y - window.AbsolutePosition.Y)
                        window.Size = UDim2.new(0, w, 0, h)
                    end)
                end
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                isMouseDown = false
                if heartbeatConn then heartbeatConn:Disconnect(); heartbeatConn = nil end
            end
        end)
    end

    do
        local toggleBtn = window:FindFirstChild("Bar"):FindFirstChild("Toggle")
        local isExpanded = true
        local canAnimate = true
        local savedVisibility = {}
        local savedHeight
        toggleBtn.MouseButton1Click:Connect(function()
            if not canAnimate then return end
            canAnimate = false
            if isExpanded then
                savedVisibility = {}
                for _, child in ipairs(window:FindFirstChild("Tabs"):GetChildren()) do
                    savedVisibility[child] = child.Visible
                    child.Visible = false
                end
                resizer.Active = false
                savedHeight = window.AbsoluteSize.Y
                tween(toggleBtn, { Rotation = 0 }, options.tween_time)
                tween(window, { Size = UDim2.new(0, window.AbsoluteSize.X, 0, 26) }, options.tween_time)
            else
                for child, wasVisible in pairs(savedVisibility) do child.Visible = wasVisible end
                resizer.Active = true
                tween(toggleBtn, { Rotation = 0 }, options.tween_time)
                tween(window, { Size = UDim2.new(0, window.AbsoluteSize.X, 0, savedHeight) }, options.tween_time)
            end
            isExpanded = not isExpanded
            task.delay(options.tween_time, function() canAnimate = true end)
        end)
    end

    do
        local tabsContainer = window:FindFirstChild("Tabs")
        local tabBar = window:FindFirstChild("TabSelection")
        local tabScrolling = tabBar:FindFirstChild("TabScrolling")
        local tabButtonsRow = tabScrolling:FindFirstChild("TabButtons")
        local activeTabBtn = nil
        local activeHbConn = nil

        local function updateTabBarWidth()
            local totalWidth = 0
            local layoutPad = tabButtonsRow:FindFirstChildOfClass("UIListLayout").Padding.Offset or 0
            for _, child in ipairs(tabButtonsRow:GetChildren()) do
                if child:IsA("TextButton") then totalWidth = totalWidth + child.AbsoluteSize.X + layoutPad end
            end
            tabButtonsRow.Size = UDim2.new(0, totalWidth, 1, 0)
            if tabScrolling then tabScrolling.CanvasSize = UDim2.new(0, totalWidth, 0, 0) end
        end

        function windowAPI:AddTab(tabName)
            local tabAPI = {}
            tabName = tostring(tabName or "New Tab")
            tabBar.Visible = true

            local tabBtn = Prefabs:FindFirstChild("TabButton"):Clone()
            tabBtn.Parent = tabButtonsRow
            tabBtn.Text = tabName
            tabBtn.Size = UDim2.new(0, getTextWidth(tabBtn) + 20, 0, 18)
            tabBtn.ZIndex = tabBtn.ZIndex + windowCount * 10
            tabBtn.BackgroundTransparency = 1
            tabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
            tabBtn.TextSize = 13
            tabBtn.Font = Enum.Font.FredokaOne

            local btnBg = tabBtn:GetChildren()[1]
            btnBg.ZIndex = tabBtn.ZIndex + windowCount * 10
            btnBg.ImageTransparency = 1

            local btnCorner = Instance.new("UICorner")
            btnCorner.CornerRadius = UDim.new(0, 4)
            btnCorner.Parent = tabBtn

            local btnStroke = Instance.new("UIStroke")
            btnStroke.Color = Color3.new(0, 0, 0)
            btnStroke.Thickness = 1.2
            btnStroke.Transparency = 0.7
            btnStroke.Parent = tabBtn

            local tabOutline = Instance.new("Frame")
            tabOutline.Name = "TabOutline"
            tabOutline.Size = UDim2.new(1, 0, 1, 0)
            tabOutline.BackgroundTransparency = 1
            tabOutline.BorderSizePixel = 2
            tabOutline.BorderColor3 = options.main_color
            tabOutline.ZIndex = tabBtn.ZIndex + 10
            tabOutline.Visible = false
            local outlineCorner = Instance.new("UICorner")
            outlineCorner.CornerRadius = UDim.new(0, 4)
            outlineCorner.Parent = tabOutline
            tabOutline.Parent = tabBtn

            local tabContent = Prefabs:FindFirstChild("Tab"):Clone()
            tabContent.Parent = tabsContainer
            tabContent.ZIndex = tabContent.ZIndex + windowCount * 10
            tabContent.Visible = false
            tabContent.ClipsDescendants = false
            tabContent.Size = UDim2.new(1, 0, 1, 0)
            tabContent.BackgroundTransparency = 1

            local scroller = Instance.new("ScrollingFrame")
            scroller.Name = "TabScroller"
            scroller.Parent = tabContent
            scroller.Size = UDim2.new(1, 0, 1, 0)
            scroller.BackgroundTransparency = 1
            scroller.BorderSizePixel = 0
            scroller.ScrollBarThickness = 4
            scroller.CanvasSize = UDim2.new(0, 0, 0, 0)
            scroller.ZIndex = tabContent.ZIndex
            scroller.ScrollBarImageColor3 = Color3.fromRGB(255, 0, 0)
            scroller.ScrollBarImageTransparency = 0.4

            local layout = tabContent:FindFirstChildOfClass("UIListLayout")
            if layout then layout.Parent = scroller end

            local function updateScrollerHeight()
                scroller.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
            end
            layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateScrollerHeight)
            updateScrollerHeight()

            task.defer(updateTabBarWidth)

            local function spawnTabParticles(tab)
                if tab ~= activeTabBtn then return end
                local size = tab.AbsoluteSize
                for _ = 1, 3 do
                    task.spawn(function()
                        local p = Instance.new("Frame")
                        p.Name = "SimpleParticle"
                        p.Size = UDim2.new(0, 1.5, 0, 1.5)
                        p.AnchorPoint = Vector2.new(0.5, 0.5)
                        p.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                        p.BorderSizePixel = 0
                        p.ZIndex = tab.ZIndex + 15
                        local pc = Instance.new("UICorner")
                        pc.CornerRadius = UDim.new(1, 0)
                        pc.Parent = p
                        local side = math.random(1, 4)
                        local px, py = 0, 0
                        if side == 1 then px = math.random(5, size.X - 5); py = 1
                        elseif side == 2 then px = size.X - 1; py = math.random(5, size.Y - 5)
                        elseif side == 3 then px = math.random(5, size.X - 5); py = size.Y - 1
                        else px = 1; py = math.random(5, size.Y - 5) end
                        p.Position = UDim2.new(0, px, 0, py)
                        p.Parent = tab
                        local cx, cy = size.X / 2, size.Y / 2
                        local dx, dy = px - cx, py - cy
                        local len = math.sqrt(dx * dx + dy * dy)
                        dx, dy = dx / len, dy / len
                        local pt = TweenService:Create(p, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                            Position = UDim2.new(0, px + dx * 6, 0, py + dy * 6),
                            BackgroundTransparency = 1
                        })
                        pt:Play()
                        task.wait(0.5)
                        if p and p.Parent then p:Destroy() end
