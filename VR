local function tween(instance, properties, duration)
    duration = duration or 0.1
    if duration == 0 then
        for prop, value in pairs(properties) do instance[prop] = value end
        return
    end
    local t = TweenService:Create(instance, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), properties)
    t:Play()
    return t
end

local function applyColor(instance, colors, rotation)
    local existing = instance:FindFirstChild("UIGradient")
    if existing then existing:Destroy() end
    if typeof(colors) == "Color3" then colors = { colors } end
    if not colors or #colors == 0 then return end
    if #colors == 1 then
        if instance:IsA("ImageLabel") or instance:IsA("ImageButton") then
            instance.ImageColor3 = colors[1]
        else
            instance.BackgroundColor3 = colors[1]
        end
        return
    end
    local gradient = Instance.new("UIGradient")
    gradient.Parent = instance
    gradient.Rotation = rotation or 0
    local kp = {}
    if #colors == 2 then
        kp = { ColorSequenceKeypoint.new(0, colors[1]), ColorSequenceKeypoint.new(1, colors[2]) }
    elseif #colors >= 3 then
        kp = { ColorSequenceKeypoint.new(0, colors[1]), ColorSequenceKeypoint.new(0.5, colors[2]), ColorSequenceKeypoint.new(1, colors[3]) }
    end
    gradient.Color = ColorSequence.new(kp)
    if instance:IsA("ImageLabel") or instance:IsA("ImageButton") then
        instance.ImageColor3 = Color3.new(1, 1, 1)
    else
        instance.BackgroundColor3 = Color3.new(1, 1, 1)
    end
end

local function rgbToHsv(r, g, b)
    r, g, b = r / 255, g / 255, b / 255
    local max, min = math.max(r, g, b), math.min(r, g, b)
    local h, s, v = 0, 0, max
    local delta = max - min
    s = max == 0 and 0 or delta / max
    if max ~= min then
        if max == r then h = (g - b) / delta + (g < b and 6 or 0)
        elseif max == g then h = (b - r) / delta + 2
        elseif max == b then h = (r - g) / delta + 4
        end
        h = h / 6
    end
    return h, s, v
end

local function safeGet(instance, property)
    local ok, value = pcall(function() return instance[tostring(property)] end)
    return ok and value
end

